import sqlite3, sys

strategy = 'MultiLsV3Strategy'
target = int(sys.argv[1])
conn = sqlite3.connect('/freqtrade/user_data/tradesv3.sqlite')
conn.row_factory = sqlite3.Row
cur = conn.cursor()
cur.execute('''
select
  sum(case when coalesce(enter_tag, '') != 'force_entry' then 1 else 0 end) as natural_count,
  sum(case when is_open = 1 and coalesce(enter_tag, '') != 'force_entry' then 1 else 0 end) as natural_open_count,
  sum(case when is_open = 0 and coalesce(enter_tag, '') != 'force_entry' then coalesce(close_profit_abs, 0) else 0 end) as natural_closed_pnl
from trades
where strategy = ?
''', (strategy,))
row = cur.fetchone()
natural_count = row['natural_count'] or 0
natural_open = row['natural_open_count'] or 0
natural_pnl = row['natural_closed_pnl'] or 0
remaining = max(target - natural_count, 0)

print(f'Strategy review gate: {strategy}')
print(f'Target natural samples: {target}')
print(f'Current natural samples: {natural_count}')
print(f'Current natural open trades: {natural_open}')
print(f'Current natural closed PnL: {natural_pnl:.6f} USDT')
if natural_count >= target:
    print('Gate status: READY_FOR_REVIEW')
    print('Next action: start strategy review using pair/exit-reason/direction stats.')
