print(f\"Last open trade: {trade_stats.get('last_open_date') or '-'}\")
print(f\"Last closed trade: {trade_stats.get('last_close_date') or '-'}\")
print(f\"Recent log scan ({tail_lines} lines): errors={pattern_counts['errors']} ws_disconnects={pattern_counts['ws_disconnects']} timeouts={pattern_counts['timeouts']}\")
if top_strategies:
