# OKX API 配置
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# 模拟盘/实盘
OKX_USE_SANDBOX=true

# Freqtrade API 配置
FREQTRADE_JWT_SECRET_KEY=change_me_to_a_random_secret
FREQTRADE_WS_TOKEN=change_me_to_a_random_ws_token
FREQTRADE_API_USERNAME=freqtrade
FREQTRADE_API_PASSWORD=change_me_to_a_strong_password

# PostgreSQL strategy registry
# Local development uses the async SQLAlchemy URL. CLI/admin scripts may convert it
# to postgresql:// temporarily when calling psql.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ouyi_db

# Strategy runtime artifacts. Generated files in these directories are runtime
# materialization outputs, not source assets.
STRATEGY_RUNTIME_DIR=execution/freqtrade/user_data/runtime_strategies
STRATEGY_PARAM_RUNTIME_DIR=execution/freqtrade/user_data/runtime_params
STRATEGY_REGISTRY_SCHEMA=public
