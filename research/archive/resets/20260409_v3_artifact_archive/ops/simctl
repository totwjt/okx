#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
COMPOSE_FILE="$ROOT_DIR/execution/freqtrade/docker-compose.yml"
CONTAINER_NAME="freqtrade"
API_BASE="http://127.0.0.1:8080/api/v1"
API_AUTH="freqtrade:freqtrade"

usage() {
  cat <<'EOF'
Usage:
  execution/scripts/simctl up
  execution/scripts/simctl down
  execution/scripts/simctl restart
  execution/scripts/simctl ps
  execution/scripts/simctl logs [tail]
  execution/scripts/simctl ping
  execution/scripts/simctl summary
  execution/scripts/simctl baseline-report [log_tail]
  execution/scripts/simctl paper-run-start <run_name> [notes]
  execution/scripts/simctl paper-run-report <run_name>
  execution/scripts/simctl show-config
  execution/scripts/simctl status
  execution/scripts/simctl balance
  execution/scripts/simctl profit
  execution/scripts/simctl recent-trades [limit]
  execution/scripts/simctl recent-trades-summary [limit]
  execution/scripts/simctl daily-report [limit_days]
  execution/scripts/simctl pair-stats
  execution/scripts/simctl exit-reason-stats
  execution/scripts/simctl direction-stats
  execution/scripts/simctl strategy-sample-status
  execution/scripts/simctl strategy-natural-trades [limit]
  execution/scripts/simctl strategy-review-gate [target_samples]
  execution/scripts/simctl force-enter <pair> <long|short> [stake_amount] [leverage]
  execution/scripts/simctl force-exit <trade_id>
  execution/scripts/simctl db-last-trades [limit]
  execution/scripts/simctl db-last-orders [limit]
EOF
}

require_container() {
  if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER_NAME"; then
    echo "Container '$CONTAINER_NAME' is not running." >&2
    exit 1
  fi
}

compose() {
  docker compose -f "$COMPOSE_FILE" "$@"
}

api_get() {
  local path="$1"
  require_container
  docker exec "$CONTAINER_NAME" sh -lc \
    "curl -sS -u '$API_AUTH' '$API_BASE/$path'"
}

api_post_json() {
  local path="$1"
  local payload="$2"
  require_container
  docker exec "$CONTAINER_NAME" python -c "
import base64, json, sys, urllib.request
payload = json.loads(sys.argv[1])
req = urllib.request.Request(
    '$API_BASE/$path',
    data=json.dumps(payload).encode(),
    headers={
        'Content-Type': 'application/json',
        'Authorization': 'Basic ' + base64.b64encode(b'$API_AUTH').decode(),
    },
    method='POST',
)
with urllib.request.urlopen(req, timeout=30) as resp:
    print(resp.read().decode())
" "$payload"
}

python_in_container() {
  local code="$1"
  shift || true
  require_container
  docker exec "$CONTAINER_NAME" python -c "$code" "$@"
}

current_strategy_name() {
  require_container
  local cmd_json strategy
  cmd_json="$(docker inspect "$CONTAINER_NAME" --format '{{json .Config.Cmd}}' 2>/dev/null || true)"
  strategy="$(printf '%s' "$cmd_json" | sed -n 's/.*"--strategy","\\([^"]*\\)".*/\\1/p')"
  if [[ -z "$strategy" ]]; then
    strategy="MultiLsV3Strategy"
  fi
  printf '%s\n' "$strategy"
}

db_query() {
  local sql="$1"
  require_container
  python_in_container "
import json, sqlite3, sys
conn = sqlite3.connect('/freqtrade/user_data/tradesv3.sqlite')
conn.row_factory = sqlite3.Row
cur = conn.cursor()
cur.execute(sys.argv[1])
print(json.dumps([dict(r) for r in cur.fetchall()], ensure_ascii=False, default=str))
" "$sql"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  up)
    compose up -d freqtrade
    ;;
  down)
    compose down
    ;;
  restart)
    compose restart freqtrade
    ;;
  ps)
    compose ps
    ;;
  logs)
    tail_lines="${1:-120}"
    docker logs --tail "$tail_lines" "$CONTAINER_NAME"
    ;;
  ping)
    api_get "ping"
    ;;
  summary)
